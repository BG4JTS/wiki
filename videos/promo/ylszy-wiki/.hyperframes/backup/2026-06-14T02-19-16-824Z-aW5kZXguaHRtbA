  {num:"009",title:'\u72D7\u7684\u4E16\u754C\u592A\u75AF\u72C2',date:"2014-04-30"},
  {num:"010",title:'\u7B11\u4E3A\u4EC0\u4E48\u4F1A\u4F20\u67D3\uFF1F',date:"2014-05-07"},
  {num:"番外",title:'\u5FAE\u4FE1\u5E73\u53F0\u6B63\u5F0F\u4E0A\u7EBF\u5566\uFF01',date:"2014-05-13"},
  {num:"011",title:'\u571F\u8C6A\u65F6\u4EE3\u8BF4\u201C\u9EC4\u91D1\u201D',date:"2014-05-13"}
];

function buildEpList(id, eps) {
  var c = document.getElementById(id);
  eps.forEach(function(e) {
    var row = document.createElement("div");
    row.className = "ep-row";
    row.innerHTML = '<span class="ep-num">#' + e.num + '</span><span class="ep-title">' + e.title + '</span><span class="ep-date">' + e.date + '</span>';
    c.appendChild(row);
  });
