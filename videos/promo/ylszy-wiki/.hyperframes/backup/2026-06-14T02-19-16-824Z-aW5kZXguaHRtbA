function staggerRows(id, baseT) {
  var rows = document.getElementById(id).querySelectorAll(".ep-row");
  rows.forEach(function(r, i) {
    tl.fromTo(r, { opacity:0, x:-30 }, { opacity:1, x:0, duration:0.4, ease:"power2.out" }, baseT + i * 0.25);
  });
}
staggerRows("ep-list-1", 5.7);
