// Host team
for (var hi = 0; hi < 6; hi++) {
  tl.fromTo(document.getElementById("h" + hi), { opacity:0, y:20 }, { opacity:1, y:0, duration:0.35, ease:"power2.out" }, 14.4 + hi * 0.15);
}
