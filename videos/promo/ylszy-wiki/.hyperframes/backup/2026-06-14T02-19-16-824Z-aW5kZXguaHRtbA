<script>
window.__timelines = window.__timelines || {};
var tl = gsap.timeline({ paused:true });

var seed = 42;
function sr() { seed = (seed * 16807) % 2147483647; return (seed - 1) / 2147483646; }

var W = 1920, H = 1080;
var dotEls = [];
for (var i = 0; i < 200; i++) {
  var dx = sr() * W, dy = sr() * H, ds = 1 + sr() * 3;
  var dh = sr() < 0.3 ? 200 : (sr() < 0.4 ? 180 : 0);
  var dsa = sr() < 0.4 ? "50%" : "0%";
  var dl = 45 + sr() * 45;
  var dot = document.createElement("div");
  dot.className = "dot";
  dot.style.cssText = "left:"+dx+"px;top:"+dy+"px;width:"+ds+"px;height:"+ds+"px;background:hsl("+dh+","+dsa+","+dl+"%);z-index:1;";
  dot._x = dx; dot._y = dy;
  document.getElementById("root").appendChild(dot);
  dotEls.push(dot);
}

function preBurst(t, cx, cy, radius, count) {
  var used = 0;
  for (var i = 0; i < dotEls.length && used < count; i++) {
    var el = dotEls[i];
    var ddx = el._x - cx, ddy = el._y - cy;
    var dist = Math.sqrt(ddx * ddx + ddy * ddy);
    if (dist < radius) {
      var angle = Math.atan2(ddy, ddx);
      var flyDist = 120 + (i % 200);
      tl.fromTo(el, { opacity:0, x:0, y:0 }, { opacity:0.9, x:Math.cos(angle)*flyDist, y:Math.sin(angle)*flyDist, duration:2.5, ease:"power2.out", overwrite:"auto" }, t);
      tl.to(el, { opacity:0, duration:1.5, overwrite:"auto" }, t + 1.8);
      used++;
    }
  }
}

for (var p = 0; p < dotEls.length; p++) {
  if (p % 15 === 0) {
    tl.to(dotEls[p], { opacity:0.5, duration:0.5, overwrite:"auto" }, 0.5 + (p % 7) * 0.5);
    tl.to(dotEls[p], { opacity:0.08, duration:0.7, overwrite:"auto" }, 1.2 + (p % 7) * 0.5);
  }
  if (p % 20 === 0) {
    tl.to(dotEls[p], { opacity:0.4, duration:0.6, overwrite:"auto" }, 6 + (p % 5) * 0.4);
    tl.to(dotEls[p], { opacity:0.08, duration:0.6, overwrite:"auto" }, 7 + (p % 5) * 0.4);
  }
  if (p % 17 === 0) {
    tl.to(dotEls[p], { opacity:0.4, duration:0.5, overwrite:"auto" }, 12 + (p % 5) * 0.3);
    tl.to(dotEls[p], { opacity:0.08, duration:0.6, overwrite:"auto" }, 13 + (p % 5) * 0.3);
  }
}

// Section transitions
tl.to("#sec-title", { opacity:1, duration:0.6, ease:"power2.out" }, 0);
tl.to("#sec-title", { opacity:0, duration:0.4 }, 2.4);
tl.set("#sec-title", { opacity:0 }, 2.8);

tl.to("#sec-data", { opacity:1, duration:0.4, ease:"power2.out" }, 2.8);
tl.to("#sec-data", { opacity:0, duration:0.3 }, 5.3);
tl.set("#sec-data", { opacity:0 }, 5.6);

tl.to("#sec-ep1", { opacity:1, duration:0.4 }, 5.6);
tl.to("#sec-ep1", { opacity:0, duration:0.3 }, 8.2);
tl.set("#sec-ep1", { opacity:0 }, 8.5);

tl.to("#sec-ep2", { opacity:1, duration:0.4 }, 8.5);
tl.to("#sec-ep2", { opacity:0, duration:0.3 }, 11.1);
tl.set("#sec-ep2", { opacity:0 }, 11.4);

tl.to("#sec-features", { opacity:1, duration:0.4, ease:"power2.out" }, 11.4);
tl.to("#sec-features", { opacity:0, duration:0.3 }, 14.0);
tl.set("#sec-features", { opacity:0 }, 14.3);

tl.to("#sec-hosts", { opacity:1, duration:0.4, ease:"power2.out" }, 14.3);
tl.to("#sec-hosts", { opacity:0, duration:0.3 }, 16.9);
tl.set("#sec-hosts", { opacity:0 }, 17.2);

tl.to("#sec-finale", { opacity:1, duration:0.5, ease:"power2.out" }, 17.2);

// Bursts
preBurst(0, 960, 540, 300, 50);
preBurst(2.8, 960, 540, 250, 30);
preBurst(5.6, 960, 540, 200, 25);
preBurst(8.5, 960, 540, 200, 25);
preBurst(11.4, 960, 540, 250, 30);
preBurst(14.3, 960, 540, 200, 25);
preBurst(17.2, 960, 540, 400, 80);
preBurst(18.5, 960, 540, 500, 120);

// Number counters
function numSteps(el, target, startT, dur, steps) {
  for (var s = 0; s <= steps; s++) {
    var v = Math.round(target * s / steps);
    (function(val) { tl.call(function(){ el.textContent = val; }, null, startT + dur * s / steps); })(v);
  }
}
numSteps(document.getElementById("dn1"), 641, 2.8, 2.2, 10);
numSteps(document.getElementById("dn2"), 361, 2.8, 2.2, 10);
